# Main MERN backend (cookies / apiFetch)
# VITE_API_BASE_URL=http://localhost:5000

# Voice microservice URL (no trailing slash). Required for production frontend builds that
# are not hosted behind `/voice/*` routing. Omit locally to use Vite proxy → localhost:4001.
# Example (Railway voice_service):
# VITE_VOICE_URL=https://smartclassroom-production-f3e7.up.railway.app

# LiveKit WebRTC (see useLiveKit.ts)
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
